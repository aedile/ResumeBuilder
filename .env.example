# Resume Builder - Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit the .env file to git!

# =============================================================================
# REQUIRED VARIABLES
# =============================================================================

# Anthropic API key for Claude integration
# Get your key at: https://console.anthropic.com/
# Format: sk-ant-...
ANTHROPIC_API_KEY=

# =============================================================================
# APPLICATION CONFIGURATION
# =============================================================================

# Environment: development, staging, production
# Default: development
RESUME_BUILDER_ENV=development

# Enable debug mode (shows detailed errors, verbose logging)
# Default: true
RESUME_BUILDER_DEBUG=true

# =============================================================================
# LOGGING CONFIGURATION
# =============================================================================

# Logging verbosity level
# Options: DEBUG, INFO, WARNING, ERROR
# Default: INFO
LOG_LEVEL=INFO

# =============================================================================
# FILE UPLOAD CONFIGURATION
# =============================================================================

# Maximum upload size in megabytes
# Default: 10
MAX_UPLOAD_SIZE_MB=10

# =============================================================================
# AI API CONFIGURATION
# =============================================================================

# Claude API request timeout in seconds
# Default: 30
API_TIMEOUT_SECONDS=30

# Enable response caching to reduce API costs
# Default: true
ENABLE_CACHE=true

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================

# Server host (typically only changed in production)
# Default: 0.0.0.0
HOST=0.0.0.0

# Server port
# Default: 8000
PORT=8000
